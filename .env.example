# Copy this file to .env and fill in local-only runtime secrets.
# Never commit .env.

# Put your provider API key here when opencode is not already authenticated.
PEN_AGENT_API_KEY=

# Provider name used when writing ~/.local/share/opencode/auth.json.
# For the current project default model, keep this as deepseek.
PEN_AGENT_PROVIDER=deepseek

# Defaults used by CLI and dashboard.
PEN_AGENT_MODEL=deepseek/deepseek-v4-flash
PEN_AGENT_ATTACH_URL=http://localhost:4096

# Optional: use a named opencode agent.
PEN_AGENT_AGENT=

# Dashboard binding.
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=3000
